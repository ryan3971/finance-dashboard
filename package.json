{
  "name": "finance-dashboard",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm dlx eslint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:studio": "pnpm --filter api db:studio",
    "seed:rules": "tsx --env-file=.env scripts/seed-rules.ts",
    "seed:dev": "tsx --env-file=.env scripts/seed-dev.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/api/src/**/*.ts": [
      "eslint --fix --max-warnings=0"
    ],
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/multer>@types/express-serve-static-core": "^5.1.1",
      "@types/multer>@types/express": "^5.0.6"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9",
    "eslint-plugin-check-file": "^2.8.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0"
  }
}