{
  "name": "finance-dashboard",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:studio": "pnpm --filter api db:studio",
    "seed:rules": "tsx --env-file=.env scripts/seed-rules.ts",
    "seed:dev": "tsx --env-file=.env scripts/seed-dev.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/api/src/**/*.ts": [
      "eslint --fix --max-warnings=0"
    ],
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
