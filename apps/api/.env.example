# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/finance_dev
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5434/finance_test

# JWT — generate both secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Each command produces a unique 64-char hex string (256-bit key). Run it twice.
# Do NOT use the placeholder values below — they will be rejected at startup.
JWT_SECRET=REPLACE_ME_run_node_-e_console.log(require('crypto').randomBytes(32).toString('hex'))
JWT_REFRESH_SECRET=REPLACE_ME_run_node_-e_console.log(require('crypto').randomBytes(32).toString('hex'))_again

# AWS (not needed until Phase 4)
AWS_REGION=
S3_BUCKET_NAME=

# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# AI Categorization
# Set to 'true' to enable AI calls during import.
# Set to 'false' (or omit) during development to avoid API costs.
ENABLE_AI_CATEGORIZATION=false
AI_CONFIDENCE_THRESHOLD=0.70
TRANSFER_DETECTION_WINDOW_DAYS=3

# AI Provider — 'anthropic' (default) | 'openai'
# Anthropic Claude Haiku is recommended: faster, cheaper, sufficient for categorization.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY is only needed if AI_PROVIDER=openai

# Sentry DSN
SENTRY_DSN=https://