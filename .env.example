# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/finance_dev
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5434/finance_test

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-32-byte-hex-secret
JWT_REFRESH_SECRET=replace-with-different-32-byte-hex-secret

# AWS (not needed until Phase 4)
AWS_REGION=
S3_BUCKET_NAME=

# App
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# AI Categorization
# Set to 'true' to enable AI calls during import.
# Set to 'false' (or omit) during development to avoid API costs.
ENABLE_AI_CATEGORIZATION=false
AI_CONFIDENCE_THRESHOLD=0.70
TRANSFER_DETECTION_WINDOW_DAYS=3

# AI Provider — 'anthropic' (default) | 'openai'
# Anthropic Claude Haiku is recommended: faster, cheaper, sufficient for categorization.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY is only needed if AI_PROVIDER=openai

# Sentry DSN
SENTRY_DSN=https://